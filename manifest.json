{
  "manifest_version": 3,
  "name": "Toxic Food Filter",
  "version": "1.0.0",
  "description": "Filter out products with potentially harmful ingredients on Instacart",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://*.instacart.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.instacart.com/*"],
      "js": ["content.js"],
      "css": ["src/styles/overlay.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["utils/*.js", "defaultIngredients.js"],
      "matches": ["*://*.instacart.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
